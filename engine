package secure_policy

import (
	"encoding/hex"
	"encoding/json"
	"fmt"
	"github.com/gddisney/ultimate_db"
)

const PolicyPageID = ultimate_db.PageID(5)

type Policy struct {
	Effect     string            `json:"effect"`     // "ALLOW" or "DENY"
	Conditions map[string]string `json:"conditions"` // Attribute constraints (e.g., "ip": "10.0.0.1")
}

type PolicyEngine struct {
	db *ultimate_db.DB
}

func NewPolicyEngine(db *ultimate_db.DB) *PolicyEngine {
	return &PolicyEngine{db: db}
}

// Evaluate performs the ABAC check.
// subject: Signer Key (identity)
// action: Operation (e.g., "read", "ingest")
// resource: Object (e.g., "logs_db")
// context: Map of current runtime attributes (e.g., IP address, session ID, service name)
func (pe *PolicyEngine) Evaluate(subject []byte, action, resource string, context map[string]string) bool {
	subjectHex := hex.EncodeToString(subject)

	// We check for specific matches AND wildcards to allow policy inheritance
	// Key: policy:<subject>:<action>:<resource>
	potentialKeys := []string{
		fmt.Sprintf("policy:%s:%s:%s", subjectHex, action, resource),
		fmt.Sprintf("policy:%s:%s:*", subjectHex, action), // Action-level wildcard
		fmt.Sprintf("policy:%s:*:*", subjectHex),           // Subject-level wildcard
	}

	txn := pe.db.BeginTxn()
	defer pe.db.CommitTxn(txn)

	for _, k := range potentialKeys {
		data, err := pe.db.Read(PolicyPageID, txn, []byte(k))
		if err != nil {
			continue // Keep searching wildcards
		}

		var p Policy
		if err := json.Unmarshal(data, &p); err != nil {
			continue
		}

		// If policy matches, evaluate conditions
		if p.Effect == "ALLOW" && pe.checkConditions(p.Conditions, context) {
			return true
		}
	}

	return false // Default DENY
}

// checkConditions compares policy requirements against actual runtime context.
func (pe *PolicyEngine) checkConditions(required map[string]string, actual map[string]string) bool {
	for k, v := range required {
		if val, ok := actual[k]; !ok || val != v {
			return false // Attribute mismatch or missing
		}
	}
	return true
}

// --- Management API ---

func (pe *PolicyEngine) AddPolicy(subject []byte, action, resource, effect string, conditions map[string]string) error {
	key := []byte(fmt.Sprintf("policy:%s:%s:%s", hex.EncodeToString(subject), action, resource))
	policy := Policy{Effect: effect, Conditions: conditions}
	data, _ := json.Marshal(policy)

	txn := pe.db.BeginTxn()
	err := pe.db.Write(PolicyPageID, txn, key, data, 0)
	pe.db.CommitTxn(txn)
	return err
}

func (pe *PolicyEngine) RemovePolicy(subject []byte, action, resource string) error {
	key := []byte(fmt.Sprintf("policy:%s:%s:%s", hex.EncodeToString(subject), action, resource))
	txn := pe.db.BeginTxn()
	// Assuming DB has a Delete function or similar
	err := pe.db.Write(PolicyPageID, txn, key, nil, 0) 
	pe.db.CommitTxn(txn)
	return err
}
